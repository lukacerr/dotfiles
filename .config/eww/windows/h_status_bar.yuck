(defwindow h_status_bar
  :monitor "DP-1"
  :stacking "fg"
  :exclusive true
  :geometry (geometry
    :x 0 :y 0
    :anchor "top center"
    :width "100%"
    :height "4.375%"
  )

  (centerbox
    :style "margin: 0.75em 1em"
    :orientation "h"

    ; Left
    (box
      :halign "start"
      :space-evenly false
      :spacing 8
      ; TODO: Workspaces, active submap, playerctl
    )

    ; Center
    (box
      :halign "center"
      :space-evenly false
      :spacing 8
      (active_app)
    )

    ; Right
    (box
      :halign "end"
      :space-evenly false
      :spacing 8
      (battery :data mouse_data :icon "" :onclick "piper &")
      (battery :data keyboard_data :icon "󰌌" :onclick "fcitx5-config-qt &")
      (battery :data earbuds_data :icon "󱡏")
      (bluetooth)
      (network)
      (audio)
    )
  )
)